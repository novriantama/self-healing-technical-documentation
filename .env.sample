# -----------------------------------------------------------------------------
# Self-Healing Technical Documentation: Environment Variables Sample
# Copy this file to '.env' and fill in your details to run the tool locally.
# -----------------------------------------------------------------------------

# Anthropic API key for Claude Sonnet 4.6 verification and repairs
# Required for non-mock runs.
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# OR use OpenAgentic.id API configuration (drop-in replacement for OpenAI endpoints)
OPENAGENTIC_API_KEY="your-openagentic-api-key-here"
OPENAGENTIC_BASE_URL="https://openagentic.id/api/v1"
OPENAGENTIC_MODEL="anthropic/claude-sonnet-4.6"

# Confidence threshold below which edits are routed to draft mode (requesting human review)
# Default is 0.8
CONFIDENCE_THRESHOLD=0.8

# Whether to auto-apply high-confidence corrections directly to local files (true/false)
# Default is true
AUTO_MERGE=true

# Path to codebase-to-docs link graph index json file
# Default is docs_index.json
INDEX_PATH="docs_index.json"

# Target workspace directory containing source code and documentation
# Default is the current directory (.)
WORKSPACE_DIR="."
